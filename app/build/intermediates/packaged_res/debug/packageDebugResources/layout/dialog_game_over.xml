<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/brand_corner_xl"
    app:cardBackgroundColor="@color/brand_surface"
    app:cardElevation="@dimen/brand_dialog_elevation"
    app:strokeWidth="1dp"
    app:strokeColor="@color/brand_outline">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/brand_spacing_l"
        android:gravity="center">

        <ImageView
            android:id="@+id/iv_result_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_check_badge"
            android:layout_marginBottom="@dimen/brand_spacing_m"
            app:tint="@color/brand_primary"/>

        <TextView
            android:id="@+id/tv_game_over_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game_over_title"
            style="@style/TextAppearance.ChessApp.Label"
            android:layout_marginBottom="@dimen/brand_spacing_s"/>

        <TextView
            android:id="@+id/tv_result_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checkmate! White wins."
            style="@style/TextAppearance.ChessApp.Headline"
            android:gravity="center"
            android:layout_marginBottom="@dimen/brand_spacing_xl"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_play_again"
            android:layout_width="match_parent"
            android:layout_height="@dimen/brand_button_height"
            android:text="@string/btn_play_again"
            style="@style/Widget.ChessApp.Button.Main"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_to_menu"
            android:layout_width="match_parent"
            android:layout_height="@dimen/brand_button_height"
            android:text="@string/btn_main_menu"
            android:layout_marginTop="@dimen/brand_spacing_s"
            style="@style/Widget.Material3.Button.TextButton"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>