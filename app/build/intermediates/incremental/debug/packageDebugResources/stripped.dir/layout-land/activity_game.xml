<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_menu">

    <!-- Golden Ratio Guideline (phi ≈ 0.618) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_golden"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.618" />

    <!-- LEFT SECTION (61.8%): Game Focus -->
    <View
        android:id="@+id/section_board"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_golden"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/brand_spacing_s"
        app:icon="@drawable/ic_back"
        app:iconTint="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_game_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="@string/status_white"
        android:textColor="?attr/colorPrimary"
        android:textSize="@dimen/brand_text_h4"
        app:layout_constraintBottom_toTopOf="@id/board_container"
        app:layout_constraintEnd_toEndOf="@id/guideline_golden"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/board_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/brand_spacing_m"
        app:cardCornerRadius="@dimen/brand_corner_m"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@id/guideline_golden"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_game_status"
        app:layout_constraintWidth_max="wrap">

        <com.chessapp.views.ChessBoardView
            android:id="@+id/chess_board_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </com.google.android.material.card.MaterialCardView>


    <!-- RIGHT SECTION (38.2%): Controls & Stats -->
    <View
        android:id="@+id/section_controls"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="#10000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_golden" />

    <!-- Opponent Info -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_player_top"
        style="@style/Widget.ChessApp.Card.Glass"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/brand_spacing_m"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_golden"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/brand_spacing_m">

            <TextView
                android:id="@+id/tv_player2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Black"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tv_black_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="monospace"
                android:text="10:00"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Game Log -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_log_sheet"
        style="@style/Widget.ChessApp.Card.Glass"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/brand_spacing_m"
        android:layout_marginVertical="@dimen/brand_spacing_s"
        app:layout_constraintBottom_toTopOf="@id/card_player_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_golden"
        app:layout_constraintTop_toBottomOf="@id/card_player_top">

        <ScrollView
            android:id="@+id/scroll_log"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/brand_spacing_s">

            <TextView
                android:id="@+id/tv_game_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/default_log_entry"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Player Info -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_player_bottom"
        style="@style/Widget.ChessApp.Card.Glass"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/brand_spacing_m"
        app:layout_constraintBottom_toTopOf="@id/game_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_golden">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/brand_spacing_m">

            <TextView
                android:id="@+id/tv_player1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="White"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tv_white_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="monospace"
                android:text="10:00"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Controls Grid -->
    <GridLayout
        android:id="@+id/game_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/brand_spacing_m"
        android:columnCount="2"
        android:rowCount="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_golden">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_undo"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="Undo"
            android:textSize="10sp"
            app:icon="@drawable/ic_undo"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hint"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="Hint"
            android:textSize="10sp"
            app:icon="@drawable/ic_about"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_resign"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="Resign"
            android:textSize="10sp"
            app:icon="@drawable/ic_exit"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_options"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="Options"
            android:textSize="10sp"
            app:icon="@drawable/ic_menu"
            app:iconSize="16dp" />
    </GridLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_thinking"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/brand_primary"
        app:layout_constraintBottom_toTopOf="@id/game_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_golden" />

</androidx.constraintlayout.widget.ConstraintLayout>
